# Redis
REDIS_URL=redis://localhost:6379
REDIS_FAIL_OPEN=true

# Gateway
PORT=8080
GATEWAY_HOST=0.0.0.0
BODY_LIMIT=1mb
MAX_HEADER_SIZE=16384
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_5000

# Rate Limiting Defaults
RATE_LIMIT_ALGORITHM=sliding_window
RATE_LIMIT_GLOBAL_RPS=1000

# Circuit Breaker Defaults
CB_ERROR_THRESHOLD=50
CB_RECOVERY_TIMEOUT_MS=30000
CB_HALF_OPEN_MAX_REQUESTS=5
CB_WINDOW_SIZE_MS=60000
CB_MIN_REQUESTS=10

# Auth
JWT_SECRET=change-me-in-production
JWT_ISSUER=throttlegate
JWT_AUDIENCE=api

# OpenTelemetry
OTEL_SERVICE_NAME=throttlegate
OTEL_METRICS_PORT=9464
OTEL_TRACES_EXPORTER=console

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# Config Hot-Reload
CONFIG_POLL_INTERVAL_MS=30000
