{
  "name": "throttlegate",
  "version": "1.0.0",
  "description": "Production-grade API Gateway with adaptive rate limiting, circuit breaking, and observability",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:lua": "vitest run tests/lua/",
    "test:integration": "vitest run tests/integration/",
    "test:chaos": "vitest run tests/integration/chaos.test.ts --timeout 60000",
    "loadtest": "k6 run k6/load-test.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docs:serve": "npx serve docs"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "zod": "^3.22.4",
    "jsonwebtoken": "^9.0.2",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.48.0",
    "@opentelemetry/auto-instrumentations-node": "^0.41.0",
    "@opentelemetry/exporter-prometheus": "^0.48.0",
    "prom-client": "^15.1.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "dotenv": "^16.3.1",
    "http-graceful-shutdown": "^3.1.13",
    "http-proxy": "^1.18.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.10",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/http-proxy": "^1.17.14",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.2.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "ioredis-mock": "^8.9.0",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2",
    "nock": "^13.5.0"
  }
}
